# ──────────────────────────────────────────────────────────────
# Neuz — .gitignore
# Sectioned. Most-specific to least-specific. Comments encouraged.
# ──────────────────────────────────────────────────────────────

# ── App runtime state ────────────────────────────────────────
# SQLite DB, WAL/SHM siblings, the first-boot key file, the
# session secret. NEVER commit any of these.
/data/
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3
*.sqlite3-journal
*.sqlite3-wal
*.sqlite3-shm
first_boot_key.txt
session_secret

# ── Build artifacts ──────────────────────────────────────────
# Tailwind-built CSS and self-hosted font files are regenerated
# at Docker build time (or via `tailwindcss` locally). Keeping
# them out keeps diffs clean.
/public/app.css
/public/app.css.map
/public/fonts/

# ── Logs & temp ──────────────────────────────────────────────
/log/
/tmp/
*.log
*.pid

# ── Ruby / Bundler ───────────────────────────────────────────
/.bundle/
/vendor/bundle/
/vendor/cache/
/vendor/ruby/
*.gem
.ruby-version
.rspec_status
/coverage/
/spec/reports/
/spec/examples.txt
/test/reports/

# Ruby debugger state
.byebug_history
.debug_history
.irb_history
.pry_history

# ── Node (just in case dev tooling needs it) ─────────────────
/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm/
.yarn/cache
.yarn/install-state.gz
package-lock.json.bak

# ── Secrets & env ────────────────────────────────────────────
# Never commit env files. If you need a template, commit
# `.env.example` instead.
.env
.env.*
!.env.example
*.key
*.pem
*.crt
*.p12
*.pfx
secrets.yml
config/master.key
config/credentials/*.key

# ── Docker / OCI ─────────────────────────────────────────────
/.docker/
docker-compose.override.yml
docker-compose.local.yml

# ── Editor & IDE ─────────────────────────────────────────────
# VS Code: keep .vscode/ shared but ignore personal overrides
.vscode/*
!.vscode/settings.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.code-snippets

# JetBrains (RubyMine etc.)
.idea/
*.iml
*.iws
*.ipr
out/

# Vim / Neovim
*.swp
*.swo
*.swn
.netrwhist
Session.vim

# Emacs
*~
\#*\#
.\#*
auto-save-list/
.dir-locals.el

# Sublime
*.sublime-project
*.sublime-workspace

# ── Operating system clutter ─────────────────────────────────
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
.fseventsd

# Linux
*~
.fuse_hidden*
.nfs*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.stackdump

# ── Misc developer scratch ───────────────────────────────────
/scratch/
/notes/
TODO.local.md
*.orig
*.bak
*.swp
.history/
docs/
.claude/

