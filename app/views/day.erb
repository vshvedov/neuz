<div class="space-y-6">
  <header class="space-y-1">
    <p class="text-xs uppercase tracking-widest text-faint">
      <a href="/month/<%= date_str[0,7] %>" class="underline-offset-2 hover:underline">← <%= Date.parse(date_str).strftime("%B %Y") %></a>
    </p>
    <h1 class="font-serif text-3xl sm:text-4xl font-semibold leading-tight"><%= Date.parse(date_str).strftime("%A, %B %-d, %Y") %></h1>
  </header>

  <% if chips.any? %><%== render(:_chips, locals: { chips: chips, selected: selected }) %><% end %>

  <% if items.empty? %>
    <%== render(:_empty) %>
  <% else %>
    <ol class="divide-y divide-rule">
      <% items.each do |item| %><%== render(:_item, locals: { item: item }) %><% end %>
    </ol>
  <% end %>
</div>
