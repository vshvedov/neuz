<%
  require "uri"
  begin
    host = URI.parse(item[:source_url]).host || ""
  rescue StandardError
    host = ""
  end
  pub = item[:published_at].is_a?(Time) ? item[:published_at] : Time.parse(item[:published_at].to_s)
  arr = item[:created_at].is_a?(Time) ? item[:created_at] : Time.parse(item[:created_at].to_s)
  format_ago = ->(t) {
    diff = Time.now.utc - t.utc
    case
    when diff < 60 then "just now"
    when diff < 3600 then "#{(diff/60).to_i}m ago"
    when diff < 86_400 then "#{(diff/3600).to_i}h ago"
    when diff < 604_800 then "#{(diff/86_400).to_i}d ago"
    else t.strftime("%b %-d")
    end
  }
  pub_ago = format_ago.call(pub)
  # If the source was published noticeably earlier than the item arrived
  # (≥1 day gap), show "from <date> · curated <relative>" so the user sees
  # at a glance that the article isn't fresh news but was picked today.
  show_arrival_separately = (arr.utc - pub.utc) > 86_400
  body_html = nil
  if item[:body] && !item[:body].strip.empty?
    require "kramdown"
    body_html = Kramdown::Document.new(item[:body], auto_ids: false, smart_quotes: %w[apos apos quot quot]).to_html
  end
%>
<li class="py-4 sm:py-5 first:pt-0">
  <article class="space-y-2">
    <h2 class="font-serif text-xl sm:text-2xl font-semibold leading-snug">
      <a href="<%= item[:source_url] %>" target="_blank" rel="noopener noreferrer" class="hover:text-accent underline-offset-2 hover:underline"><%= item[:title] %></a>
    </h2>
    <p class="flex flex-wrap items-center gap-x-2 gap-y-1 text-xs text-faint">
      <span class="inline-flex items-center gap-1">
        <svg class="w-3.5 h-3.5" aria-hidden="true"><use href="#ph-link-simple"/></svg>
        <span><%= host %></span>
      </span>
      <span aria-hidden="true">·</span>
      <% if show_arrival_separately %>
        <span title="Source published <%= pub.utc.iso8601 %>">from <%= pub.strftime("%b %-d") %></span>
        <span aria-hidden="true">·</span>
        <time datetime="<%= arr.utc.iso8601 %>" title="Arrived <%= arr.utc.iso8601 %>">curated <%= format_ago.call(arr) %></time>
      <% else %>
        <time datetime="<%= pub.utc.iso8601 %>" title="<%= pub.utc.iso8601 %>"><%= pub_ago %></time>
      <% end %>
      <% if item[:category] %><span aria-hidden="true">·</span><span class="text-faint"><%= item[:category] %></span><% end %>
      <% if item[:importance] %><span aria-hidden="true">·</span><span class="text-accent" aria-label="Importance <%= item[:importance] %> of 5"><%= "★" * item[:importance] %></span><% end %>
    </p>
    <% if item[:summary] && !item[:summary].empty? %>
      <p class="text-base leading-relaxed text-ink/90"><%= item[:summary] %></p>
    <% end %>
    <% if body_html %>
      <details class="text-sm">
        <summary class="cursor-pointer text-faint hover:text-ink select-none">More</summary>
        <div class="prose mt-2"><%== body_html %></div>
      </details>
    <% end %>
    <% if item[:tags] && item[:tags].any? %>
      <ul class="flex flex-wrap gap-1.5 pt-1">
        <% item[:tags].each do |t| %>
          <li class="text-xs px-2 py-0.5 rounded-full bg-tag text-ink/80"><%= t %></li>
        <% end %>
      </ul>
    <% end %>
  </article>
</li>
